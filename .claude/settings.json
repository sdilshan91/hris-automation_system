{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Agent",
      "mcp__github__*",
      "Bash(dotnet build *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)",
      "PowerShell(dotnet user-secrets set \"ConnectionStrings:DefaultConnection\" \"Host=localhost;Port=5432;Database=hris_dev_db;Username=developer;Password=Sanjesi#123\" --project src/backend/HRM.Api/HRM.Api.csproj)",
      "PowerShell(dotnet user-secrets list --project src/backend/HRM.Api/HRM.Api.csproj)",
      "PowerShell(winget install --id Obsidian.Obsidian -e --source winget --accept-source-agreements --accept-package-agreements)",
      "Bash(mkdir -p .claude/commands)",
      "Bash(gh auth *)",
      "Bash(gh repo *)"
    ],
    "additionalDirectories": [
      "C:\\HRIS\\.claude"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-user-story-commit.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post-dev-commit.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}"
      }
    }
  }
}
