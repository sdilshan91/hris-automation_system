{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Agent",
      "mcp__github__*",
      "Bash(dotnet build *)",
      "Bash(git add *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-user-story-commit.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post-dev-commit.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}"
      }
    }
  }
}
