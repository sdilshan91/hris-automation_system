{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=hris_dev_db;Username=developer;Password="
  },
  "Jwt": {
    "Issuer": "hrm-api",
    "Audience": "hrm-client",
    "PrivateKey": ""
  },
  "Platform": {
    "BaseDomain": "yourhrm.com",
    "ReservedSubdomains": [
      "www", "api", "admin", "app", "mail", "status", "docs",
      "help", "support", "static", "cdn", "dev", "stage", "prod", "test", "qa"
    ]
  },
  "Hangfire": {
    "DashboardPath": "/hangfire"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
