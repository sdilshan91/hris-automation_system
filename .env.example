# ============================================
# HRM SaaS Automation System - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# Never commit .env to git!

# GitHub Personal Access Token
# Required scopes: repo, workflow, issues, pull_requests
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API Key (for local agent execution)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Backend DB connection (overrides the blank password in appsettings*.json)
# Either export this env var or use `dotnet user-secrets` inside src/backend/HRM.Api.
# ASP.NET Core auto-binds double-underscore env vars to nested config keys.
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=hris_dev_db;Username=developer;Password=changeme
